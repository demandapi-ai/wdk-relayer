# BSC-Solana Relayer Config

# Server
PORT=3002

# BSC Testnet
BSC_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545/
BSC_PRIVATE_KEY=your_bsc_private_key_hex
INTENT_HTLC_ADDRESS=your_deployed_contract_address

# Solana Devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_PRIVATE_KEY=[array_of_bytes]

# Solana Program ID (intent_swap)
SOLANA_PROGRAM_ID=5JAWumq5L4B8WrpF3CFox36SZ2bJF4xQvskLksmHRgs2

# Timelocks (seconds)
SOURCE_TIMELOCK=7200
DEST_TIMELOCK=3600

# Poll interval (ms)
POLL_INTERVAL_MS=5000
