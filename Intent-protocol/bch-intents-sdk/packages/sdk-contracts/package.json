{
    "name": "@bch-intents/sdk-contracts",
    "version": "0.1.0",
    "description": "Pre-compiled CashScript artifacts and TypeScript compilation wrappers for BCH Intents",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "scripts": {
        "build": "tsc",
        "clean": "rm -rf dist",
        "typecheck": "tsc --noEmit",
        "test": "node --import tsx --test src/**/*.test.ts"
    },
    "dependencies": {
        "@bch-intents/sdk-common": "*",
        "cashscript": "^0.12.0"
    },
    "devDependencies": {
        "@types/node": "^20.12.7",
        "tsx": "^4.7.0",
        "typescript": "^5.3.3"
    },
    "files": [
        "dist",
        "artifacts"
    ],
    "license": "MIT"
}