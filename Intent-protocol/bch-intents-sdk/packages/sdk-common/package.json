{
    "name": "@bch-intents/sdk-common",
    "version": "0.1.0",
    "description": "Shared types, utilities, and error classes for the BCH Intents SDK",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
